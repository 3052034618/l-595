      </tr>
      <tr>
        <td><b>整改完成率</b></td>
        <td><b>0%</b></td>
      </tr>
    </table>
  </div>

  <div class="section">
    <div class="section-title">五、平均处理时长</div>
    <table>
      <tr><th>指标</th><th>数值</th></tr>
      <tr><td>平均处理时长（小时）</td><td><b class="medium">0 h</b></td></tr>
