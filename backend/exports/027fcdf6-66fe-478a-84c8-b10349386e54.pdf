        <div class="stat-value high">0</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">中风险发现</div>
        <div class="stat-value medium">0</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">低风险发现</div>
        <div class="stat-value low">0</div>
